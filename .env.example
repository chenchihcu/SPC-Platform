# Optional runtime/testing environment variables
# Copy this file to .env and fill in real values — .env is gitignored.

# DeepSeek API key  (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# Enable offscreen Qt rendering for headless test environments.
QT_QPA_PLATFORM=offscreen

# Enable UI diagnostics snapshot logging (0/1).
SPC_UI_DIAGNOSTICS=0

# DPI behavior overrides (optional; leave default unless troubleshooting).
QT_ENABLE_HIGHDPI_SCALING=1
QT_AUTO_SCREEN_SCALE_FACTOR=1
QT_SCALE_FACTOR_ROUNDING_POLICY=RoundPreferFloor
