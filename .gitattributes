# Normalize line endings for cross-platform clones (GitHub / Windows / macOS / Linux).
* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.db binary
*.pptx binary
*.ttf binary
*.otf binary
*.ttc binary
